{
  "name": "python-expression-visualizer",
  "displayName": "Python Expression Visualizer",
  "description": "Render highlighted Python math expressions as formatted LaTeX equations",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pythonVisualizer.visualize",
        "title": "Visualize Expression"
      },
      {
        "command": "pythonVisualizer.quickPreview",
        "title": "Quick Equation Preview"
      }
    ],
    "keybindings": [
      {
        "command": "pythonVisualizer.quickPreview",
        "key": "shift+alt+v",
        "when": "editorHasSelection && editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "pythonVisualizer.visualize",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "dependencies": {
    "katex": "^0.16.9"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
